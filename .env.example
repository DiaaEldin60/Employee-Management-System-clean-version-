# ===============================
# DATABASE CONFIG
# ===============================
DB_URL=jdbc:mysql://localhost:3306/ems_db
DB_USERNAME=your_db_username
DB_PASSWORD=your_db_password

# ===============================
# SPRING CONFIG
# ===============================
SPRING_PROFILES_ACTIVE=dev
SERVER_PORT=8080

# ===============================
# LOGGING
# ===============================
LOG_LEVEL=INFO

# ===============================
# OPTIONAL SERVICES
# ===============================
# REDIS_HOST=localhost
# REDIS_PORT=6379

# ===============================
# DOCKER (if used)
# ===============================
# MYSQL_ROOT_PASSWORD=root

# ===============================
# BREVO REST API CONFIGURATION
# ===============================
# Get your API key from https://app.brevo.com/settings/keys/api
# The API key format is: xkeysib-...
BREVO_API_KEY=any_thing
# Set a sender email address (must be a verified sender in Brevo)
BREVO_FROM_EMAIL=your-email@example.com
